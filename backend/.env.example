# =============================================================================
# Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development           # "development" | "production"

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/employee_management

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_char_random_hex
JWT_REFRESH_SECRET=replace_with_another_64_char_random_hex
JWT_ACCESS_EXPIRES_IN=15m      # Short-lived access token
JWT_REFRESH_EXPIRES_IN=7d      # Long-lived refresh token (stored hashed in DB)

# ── Cookie ────────────────────────────────────────────────────────────────────
COOKIE_SECRET=replace_with_random_cookie_signing_secret

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
# For Gmail: enable "App Passwords" (2FA must be on) or use an SMTP relay.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false             # true for port 465, false for 587 (STARTTLS)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="EMS Portal <noreply@yourdomain.com>"

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Set Authorized redirect URI to: http://localhost:5000/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── Frontend ──────────────────────────────────────────────────────────────────
# Used by the backend to build email links and OAuth redirect URIs
CLIENT_URL=http://localhost:5173
