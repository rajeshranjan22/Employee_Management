# Frontend Environment Variables
# Copy this file to .env and fill in the values.

# Backend API base URL (must end with /api)
VITE_API_URL=http://localhost:5000/api

# Google OAuth Client ID (frontend display only — the backend Passport.js strategy
# is what actually validates the OAuth flow; this is used only if you switch to
# the client-side @react-oauth/google credential flow in future).
# Get yours at https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
